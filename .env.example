# =============================================================================
# OpenClaw + OpenCode Orchestration — 環境変数テンプレート
# このファイルをコピーして .env を作成し、値を設定してください
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM プロバイダー (少なくとも1つ必須)
# -----------------------------------------------------------------------------

# Anthropic (推奨: claude-sonnet-4-5 / claude-opus-4-5)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (オプション)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini (オプション)
GEMINI_API_KEY=

# AWS Bedrock (オプション)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1

# -----------------------------------------------------------------------------
# OpenClaw Gateway
# -----------------------------------------------------------------------------

# Gateway認証トークン (openssl rand -hex 32 で生成推奨)
OPENCLAW_GATEWAY_TOKEN=change-me-generate-with-openssl-rand-hex-32

# Gatewayポート (デフォルト: 18789)
OPENCLAW_GATEWAY_PORT=18789

# Bridgeポート (デフォルト: 18790)
OPENCLAW_BRIDGE_PORT=18790

# -----------------------------------------------------------------------------
# OpenCode Server
# -----------------------------------------------------------------------------

# OpenCodeサーバー認証パスワード
OPENCODE_SERVER_PASSWORD=change-me-strong-password

# OpenCodeサーバーユーザー名 (デフォルト: opencode)
OPENCODE_SERVER_USERNAME=opencode

# OpenCodeサーバーポート (デフォルト: 4096)
OPENCODE_SERVER_PORT=4096

# 使用モデル (デフォルト: anthropic/claude-sonnet-4-5)
OPENCODE_MODEL=anthropic/claude-sonnet-4-5

# -----------------------------------------------------------------------------
# チャネル連携 (オプション)
# 使用するチャネルのみコメントを外して設定
# -----------------------------------------------------------------------------

# Slack
# SLACK_BOT_TOKEN=xoxb-xxxx
# SLACK_APP_TOKEN=xapp-xxxx

# Discord
# DISCORD_TOKEN=xxxxxxxx

# Telegram
# TELEGRAM_BOT_TOKEN=xxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LINE
# LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxx
# LINE_CHANNEL_SECRET=xxxxxxxx

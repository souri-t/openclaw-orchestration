# 機密情報
.env

# OpenClaw エージェント設定 (APIキーを含むため除外)
openclaw/agents/main/
!openclaw/agents/.gitkeep

# openclaw.json は setup.sh がテンプレートから生成するため除外 (トークンを含む)
openclaw/openclaw.json
openclaw/openclaw.json.bak
openclaw/openclaw.json.bak.*

# configure / runtime 時に自動生成される OpenClaw ローカルデータ
openclaw/canvas/
openclaw/cron/
openclaw/devices/
openclaw/identity/
openclaw/logs/
openclaw/update-check.json

# OpenCode 内部状態 (セッション履歴・SQLite DB)
opencode-data/

# Docker volumes (ローカルマウントのキャッシュ)
.docker/

# OpenClaw ローカルデータ (volume以外にホストマウントする場合)
openclaw-data/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# テスト出力
projects/test-output.txt

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# ログ
*.log
